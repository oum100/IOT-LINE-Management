generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Machine {
  id                String           @id @default(cuid())
  tenantId          String?
  merchantAccountId String?
  branchId          String?
  assetId           String?
  code              String           @unique
  name              String
  kind              String
  status            MachineStatus    @default(AVAILABLE)
  locationLabel     String
  topic             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  remainingMinutes  Int?
  commands          DeviceCommand[]
  prices            MachinePrice[]
  orderItems        OrderItem[]
  tenant            Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  merchantAccount   MerchantAccount? @relation(fields: [merchantAccountId], references: [id], onDelete: SetNull)
  branch            Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  asset             Asset?           @relation(fields: [assetId], references: [id], onDelete: SetNull)
  machineKind       MachineKind      @relation(fields: [kind], references: [code], onDelete: Restrict)

  @@index([tenantId, branchId])
  @@index([merchantAccountId])
  @@index([assetId])
}

model MachinePrice {
  id              String      @id @default(cuid())
  machineId       String
  label           String
  amount          Int
  durationMinutes Int
  sortOrder       Int         @default(0)
  machine         Machine     @relation(fields: [machineId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
}

model Order {
  id                    String           @id @default(cuid())
  tenantId              String?
  merchantAccountId     String?
  branchId              String?
  paymentIntentPublicId String?
  orderNumber           String           @unique
  customerName          String
  lineUserId            String?
  note                  String?
  selfCancelTokenHash   String?
  selfCancelTokenIssuedAt DateTime?
  totalAmount           Int
  status                OrderStatus      @default(PENDING_PAYMENT)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  items                 OrderItem[]
  payment               Payment?
  refunds               Refund[]
  tenant                Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  merchantAccount       MerchantAccount? @relation(fields: [merchantAccountId], references: [id], onDelete: SetNull)
  branch                Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, createdAt])
  @@index([merchantAccountId, createdAt])
  @@index([paymentIntentPublicId])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  machineId       String
  assetId         String?
  productId       String?
  priceId         String
  priceLabel      String
  amount          Int
  durationMinutes Int
  serviceModeSnapshot ServiceMode?
  unitSnapshot    ServiceUnit?
  quantitySnapshot Decimal?       @db.Decimal(12, 3)
  status          OrderItemStatus @default(PENDING)
  startedAt       DateTime?
  completedAt     DateTime?
  machine         Machine         @relation(fields: [machineId], references: [id])
  asset           Asset?          @relation(fields: [assetId], references: [id], onDelete: SetNull)
  product         Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  price           MachinePrice    @relation(fields: [priceId], references: [id])
  refundItems     RefundItem[]

  @@index([assetId])
  @@index([productId])
}

model Payment {
  id                      String           @id @default(cuid())
  orderId                 String           @unique
  tenantId                String?
  merchantAccountId       String?
  branchId                String?
  billerProfileId         String?
  providerCode            String?
  providerPaymentIntentId String?
  providerReference       String?
  amount                  Int
  qrPayload               String
  status                  PaymentStatus    @default(PENDING)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  verifiedAt              DateTime?
  rejectedNote            String?
  order                   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds                 Refund[]
  slips                   PaymentSlip[]
  tenant                  Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  merchantAccount         MerchantAccount? @relation(fields: [merchantAccountId], references: [id], onDelete: SetNull)
  branch                  Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  billerProfile           BillerProfile?   @relation(fields: [billerProfileId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, status])
  @@index([merchantAccountId, status])
  @@index([billerProfileId, status])
  @@index([providerPaymentIntentId])
}

model BillerProfile {
  id                   String               @id @default(cuid())
  tenantId             String
  code                 String
  displayName          String
  providerCode         String
  integrationMode      IntegrationMode      @default(PLATFORM_QR)
  status               BillerStatus         @default(ACTIVE)
  priority             Int                  @default(100)
  providerConnectionId String?
  billerId             String?
  shopId               String?
  accountName          String?
  bankName             String?
  accountNumber        String?
  promptPayTarget      String?
  slipVerifyConnectionId String?
  credentials          Json?
  config               Json?
  metadata             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  providerConnection   ProviderConnection?   @relation(fields: [providerConnectionId], references: [id], onDelete: SetNull)
  slipVerifyConnection SlipVerifyConnection? @relation(fields: [slipVerifyConnectionId], references: [id], onDelete: SetNull)
  payments             Payment[]
  tenantBindings       TenantBillerBinding[]
  merchantBindings     MerchantBillerBinding[]
  branchBindings       BranchBillerBinding[]

  @@unique([tenantId, code])
  @@index([tenantId, providerCode, integrationMode, status, priority])
  @@index([providerConnectionId])
  @@index([slipVerifyConnectionId])
  @@map("biller_profiles")
}

model ProviderConnection {
  id                 String        @id @default(cuid())
  tenantId           String
  code               String
  displayName        String
  providerServiceId  String?
  providerCode       String
  status             BillerStatus  @default(ACTIVE)
  baseUrl            String?
  appKey             String?
  appSecret          String?
  webhookSecret      String?
  supportsQrIssue    Boolean       @default(false)
  supportsCallback   Boolean       @default(false)
  supportsSlipVerify Boolean       @default(false)
  credentials        Json?
  metadata           Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  providerService  ProviderService? @relation(fields: [providerServiceId], references: [id], onDelete: SetNull)
  billerProfiles   BillerProfile[]

  @@unique([tenantId, code])
  @@index([tenantId, providerCode, status])
  @@index([providerServiceId])
  @@map("provider_connections")
}

model ProviderService {
  id                        String              @id @default(cuid())
  tenantId                  String?
  code                      String
  displayName               String
  serviceType               ProviderServiceType
  status                    BillerStatus        @default(ACTIVE)
  supportsQrGeneration      Boolean             @default(false)
  supportsConfirmCallback   Boolean             @default(false)
  supportsSingleTxnVerify   Boolean             @default(false)
  supportsSingleSlipVerify  Boolean             @default(false)
  isDefault                 Boolean             @default(false)
  metadata                  Json?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  providerConnections ProviderConnection[]

  @@unique([tenantId, code])
  @@index([serviceType, status])
  @@index([tenantId, serviceType, status])
  @@map("provider_services")
}

model SlipVerifyConnection {
  id            String       @id @default(cuid())
  tenantId      String
  code          String
  displayName   String
  providerCode  String
  status        BillerStatus @default(ACTIVE)
  baseUrl       String?
  appKey        String?
  appSecret     String?
  webhookSecret String?
  credentials   Json?
  metadata      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  billerProfiles BillerProfile[]

  @@unique([tenantId, code])
  @@index([tenantId, providerCode, status])
  @@map("slip_verify_connections")
}

model TenantBillerBinding {
  id              String   @id @default(cuid())
  tenantId        String
  billerProfileId String
  isDefault       Boolean  @default(true)
  priority        Int      @default(100)
  active          Boolean  @default(true)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  billerProfile BillerProfile @relation(fields: [billerProfileId], references: [id], onDelete: Cascade)

  @@unique([tenantId, billerProfileId])
  @@index([tenantId, active, isDefault, priority])
  @@map("tenant_biller_bindings")
}

model MerchantBillerBinding {
  id                String   @id @default(cuid())
  tenantId          String
  merchantAccountId String
  billerProfileId   String
  isDefault         Boolean  @default(false)
  priority          Int      @default(100)
  active            Boolean  @default(true)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  merchantAccount MerchantAccount @relation(fields: [merchantAccountId], references: [id], onDelete: Cascade)
  billerProfile   BillerProfile   @relation(fields: [billerProfileId], references: [id], onDelete: Cascade)

  @@unique([merchantAccountId, billerProfileId])
  @@index([tenantId, merchantAccountId, active, isDefault, priority])
  @@map("merchant_biller_bindings")
}

model BranchBillerBinding {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String
  billerProfileId String
  isDefault       Boolean  @default(false)
  priority        Int      @default(100)
  active          Boolean  @default(true)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  billerProfile BillerProfile @relation(fields: [billerProfileId], references: [id], onDelete: Cascade)

  @@unique([branchId, billerProfileId])
  @@index([tenantId, branchId, active, isDefault, priority])
  @@map("branch_biller_bindings")
}

model PaymentSlip {
  id         String   @id @default(cuid())
  paymentId  String
  fileName   String
  mimeType   String?
  filePath   String
  uploadedAt DateTime @default(now())
  payment    Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model DeviceCommand {
  id             String              @id @default(cuid())
  orderId        String
  machineId      String
  commandType    String
  payloadJson    String
  status         DeviceCommandStatus @default(PENDING)
  queuedAt       DateTime            @default(now())
  acknowledgedAt DateTime?
  completedAt    DateTime?
  errorMessage   String?
  machine        Machine             @relation(fields: [machineId], references: [id])
}

model MachineKind {
  code      String   @id
  name      String
  active    Boolean  @default(true)
  sortOrder Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets   Asset[]
  products Product[]
  machines Machine[]

  @@index([active, sortOrder])
  @@map("machine_kinds")
}

enum MachineStatus {
  AVAILABLE
  RESERVED
  RUNNING
  MAINTENANCE
}

enum OrderStatus {
  PENDING_PAYMENT
  SLIP_UPLOADED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  SLIP_UPLOADED
  VERIFIED
  REJECTED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  PROCESSING
  REFUNDED
  FAILED
  REJECTED
}

enum DeviceCommandStatus {
  PENDING
  SENT
  ACKNOWLEDGED
  COMPLETED
  FAILED
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum MerchantStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum BranchStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum EnvironmentMode {
  TEST
  LIVE
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum IotDeviceStatus {
  SPARE
  IN_USE
  OFFLINE
  DISABLED
}

enum MachineUnitStatus {
  SPARE
  IN_USE
  OFFLINE
  DISABLED
}

enum ProductPricingType {
  STANDARD
  PROMOTION
  SPECIAL
}

enum ServiceMode {
  TIME
  QUANTITY
  UNIT
}

enum ServiceUnit {
  MINUTE
  SECOND
  LITER
  GRAM
  PIECE
  BOX
  SLOT
}

enum DeviceBindingStatus {
  ACTIVE
  INACTIVE
}

enum AppUserRole {
  ADMIN
  USER
  OWNER
  MANAGER
  STAFF
}

enum UserScopeType {
  MERCHANT
  BRANCH
}

enum DeviceKeyStatus {
  ACTIVE
  REVOKED
}

enum DeviceRegistrationStatus {
  READY
  USED
  EXPIRED
  REVOKED
}

enum ProviderServiceType {
  PAYMENT_GATEWAY
  SLIP_VERIFY
  BANK_API
}

enum BillerStatus {
  ACTIVE
  INACTIVE
  DISABLED
}

enum IntegrationMode {
  PLATFORM_QR
  PROVIDER_QR
}

enum ExpenseTypeStatus {
  ACTIVE
  INACTIVE
}

model Tenant {
  id        String       @id @default(cuid())
  code      String       @unique
  name      String
  status    TenantStatus @default(ACTIVE)
  metadata  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  merchantAccounts        MerchantAccount[]
  branches                Branch[]
  assets                  Asset[]
  assetBindings           AssetBinding[]
  assetProductPrices      AssetProductPrice[]
  assetProductOffers      AssetProductOffer[]
  machineUnits            MachineUnit[]
  iotDevices              IotDevice[]
  products                Product[]
  machines                Machine[]
  orders                  Order[]
  payments                Payment[]
  billerProfiles          BillerProfile[]
  providerConnections     ProviderConnection[]
  providerServices        ProviderService[]
  slipVerifyConnections   SlipVerifyConnection[]
  tenantBillerBindings    TenantBillerBinding[]
  merchantBillerBindings  MerchantBillerBinding[]
  branchBillerBindings    BranchBillerBinding[]
  users                   User[]
  userScopeAssignments    UserScopeAssignment[]
  deviceRegistrationCodes DeviceRegistrationCode[]
  expenseTypes            ExpenseType[]
  expenses                Expense[]

  @@index([status])
  @@map("tenants")
}

model MerchantAccount {
  id          String          @id @default(cuid())
  tenantId    String
  code        String
  name        String
  status      MerchantStatus  @default(ACTIVE)
  environment EnvironmentMode @default(TEST)
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branches                Branch[]
  machines                Machine[]
  orders                  Order[]
  payments                Payment[]
  billerBindings          MerchantBillerBinding[]
  users                   User[]
  userScopeAssignments    UserScopeAssignment[]
  deviceRegistrationCodes DeviceRegistrationCode[]
  expenses                Expense[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("merchant_accounts")
}

model Branch {
  id                String       @id @default(cuid())
  tenantId          String
  merchantAccountId String?
  code              String
  name              String
  status            BranchStatus @default(ACTIVE)
  metadata          Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  merchantAccount         MerchantAccount?         @relation(fields: [merchantAccountId], references: [id], onDelete: SetNull)
  assets                  Asset[]
  machines                Machine[]
  orders                  Order[]
  payments                Payment[]
  billerBindings          BranchBillerBinding[]
  userScopeAssignments    UserScopeAssignment[]
  deviceRegistrationCodes DeviceRegistrationCode[]
  expenses                Expense[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([merchantAccountId])
  @@map("branches")
}

model ExpenseType {
  id        String            @id @default(cuid())
  tenantId  String
  code      String
  name      String
  status    ExpenseTypeStatus @default(ACTIVE)
  sortOrder Int               @default(100)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([tenantId, code])
  @@index([tenantId, status, sortOrder])
  @@map("expense_types")
}

model Expense {
  id                String   @id @default(cuid())
  tenantId          String
  merchantAccountId String?
  branchId          String?
  expenseTypeId     String
  amount            Int
  occurredAt        DateTime
  note              String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  merchantAccount MerchantAccount? @relation(fields: [merchantAccountId], references: [id], onDelete: SetNull)
  branch          Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  expenseType     ExpenseType     @relation(fields: [expenseTypeId], references: [id], onDelete: Restrict)

  @@index([tenantId, occurredAt])
  @@index([merchantAccountId, occurredAt])
  @@index([branchId, occurredAt])
  @@index([expenseTypeId, occurredAt])
  @@map("expenses")
}

model Asset {
  id        String      @id @default(cuid())
  tenantId  String
  branchId  String
  assetUuid String      @unique
  code      String
  name      String
  kind      String
  status    AssetStatus @default(ACTIVE)
  metadata  Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  machineKind MachineKind        @relation(fields: [kind], references: [code], onDelete: Restrict)
  machines   Machine[]
  bindings   AssetBinding[]
  prices     AssetProductPrice[]
  offers     AssetProductOffer[]
  orderItems OrderItem[]

  @@unique([branchId, code])
  @@index([tenantId, branchId, status])
  @@map("assets")
}

model MachineUnit {
  id        String   @id @default(cuid())
  tenantId  String
  serialNo  String   @unique
  status    MachineUnitStatus @default(SPARE)
  brand     String?
  model     String?
  warrantyStartAt DateTime?
  warrantyEndAt DateTime?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bindings AssetBinding[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("machine_units")
}

model IotDevice {
  id         String   @id @default(cuid())
  tenantId   String
  macAddress String   @unique
  deviceUid  String?  @unique
  name       String?
  model      String?
  status     IotDeviceStatus @default(SPARE)
  fwVersion  String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bindings                AssetBinding[]
  keys                    DeviceApiKey[]
  deviceRegistrationCodes DeviceRegistrationCode[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("iot_devices")
}

model AssetBinding {
  id            String              @id @default(cuid())
  tenantId      String
  assetId       String
  machineUnitId String?
  iotDeviceId   String?
  status        DeviceBindingStatus @default(ACTIVE)
  startedAt     DateTime            @default(now())
  endedAt       DateTime?
  reason        String?
  metadata      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset       Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  machineUnit MachineUnit? @relation(fields: [machineUnitId], references: [id], onDelete: SetNull)
  iotDevice   IotDevice?   @relation(fields: [iotDeviceId], references: [id], onDelete: SetNull)

  @@index([tenantId, assetId, status])
  @@index([machineUnitId])
  @@index([iotDeviceId])
  @@map("asset_bindings")
}

model Product {
  id        String      @id @default(cuid())
  tenantId  String
  code      String
  name      String
  kind      String
  amount    Int?
  durationMinutes Int?
  serviceMode ServiceMode @default(TIME)
  serviceUnit ServiceUnit @default(MINUTE)
  quantity  Decimal?    @db.Decimal(12, 3)
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  machineKind MachineKind         @relation(fields: [kind], references: [code], onDelete: Restrict)
  prices      AssetProductPrice[]
  offers      AssetProductOffer[]
  orderItems  OrderItem[]

  @@unique([tenantId, code])
  @@index([tenantId, kind, active])
  @@map("products")
}

model AssetProductPrice {
  id              String   @id @default(cuid())
  tenantId        String
  assetId         String
  productId       String
  amount          Int
  durationMinutes Int
  serviceMode     ServiceMode @default(TIME)
  serviceUnit     ServiceUnit @default(MINUTE)
  quantity        Decimal?    @db.Decimal(12, 3)
  slotNo          Int?
  stockQty        Int?
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([assetId, productId])
  @@index([tenantId, assetId, active])
  @@map("asset_product_prices")
}

model AssetProductOffer {
  id              String             @id @default(cuid())
  tenantId        String
  assetId         String
  productId       String
  pricingType     ProductPricingType @default(STANDARD)
  amount          Int
  durationMinutes Int
  serviceMode     ServiceMode @default(TIME)
  serviceUnit     ServiceUnit @default(MINUTE)
  quantity        Decimal?    @db.Decimal(12, 3)
  priority        Int                @default(100)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  active          Boolean            @default(true)
  reason          String?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, assetId, active, effectiveFrom, effectiveTo])
  @@index([tenantId, productId, active, pricingType])
  @@index([assetId, productId, pricingType, active])
  @@map("asset_product_offers")
}

model Refund {
  id                String       @id @default(cuid())
  orderId           String
  paymentId         String?
  tenantId          String?
  merchantAccountId String?
  branchId          String?
  status            RefundStatus @default(REQUESTED)
  reason            String
  note              String?
  totalAmount       Int
  requestedByUserId String?
  approvedByUserId  String?
  approvedAt        DateTime?
  providerRefundRef String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment   Payment?          @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  items     RefundItem[]
  auditLogs RefundAuditLog[]

  @@index([orderId, status, createdAt])
  @@index([paymentId, status])
  @@index([tenantId, status])
  @@map("refunds")
}

model RefundItem {
  id          String   @id @default(cuid())
  refundId    String
  orderItemId String
  amount      Int
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  refund    Refund    @relation(fields: [refundId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)

  @@index([orderItemId])
  @@unique([refundId, orderItemId])
  @@map("refund_items")
}

model RefundAuditLog {
  id                String       @id @default(cuid())
  refundId          String
  fromStatus        RefundStatus?
  toStatus          RefundStatus
  action            String
  actorUserId       String?
  note              String?
  providerRefundRef String?
  metadata          Json?
  createdAt         DateTime     @default(now())

  refund Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)

  @@index([refundId, createdAt])
  @@index([toStatus, createdAt])
  @@map("refund_audit_logs")
}

model User {
  id                String      @id @default(cuid())
  tenantId          String?
  merchantAccountId String?
  email             String      @unique
  name              String?
  passwordHash      String?
  role              AppUserRole @default(USER)
  emailVerified     DateTime?
  image             String?
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  merchantAccount MerchantAccount? @relation(fields: [merchantAccountId], references: [id], onDelete: SetNull)
  accounts        Account[]
  sessions        Session[]
  scopeAssignments UserScopeAssignment[]

  @@index([tenantId, role, isActive])
  @@index([merchantAccountId])
  @@map("users")
}

model UserScopeAssignment {
  id                String        @id @default(cuid())
  userId            String
  tenantId          String
  scopeType         UserScopeType
  merchantAccountId String?
  branchId          String?
  active            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  merchantAccount MerchantAccount? @relation(fields: [merchantAccountId], references: [id], onDelete: SetNull)
  branch          Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([userId, active])
  @@index([tenantId, scopeType, active])
  @@index([merchantAccountId, active])
  @@index([branchId, active])
  @@map("user_scope_assignments")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model DeviceApiKey {
  id          String          @id @default(cuid())
  iotDeviceId String
  keyPrefix   String          @unique
  secretHash  String
  label       String?
  status      DeviceKeyStatus @default(ACTIVE)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  iotDevice IotDevice @relation(fields: [iotDeviceId], references: [id], onDelete: Cascade)

  @@index([iotDeviceId, status])
  @@index([expiresAt])
  @@map("device_api_keys")
}

model DeviceRegistrationCode {
  id                String                   @id @default(cuid())
  tenantId          String
  merchantAccountId String?
  branchId          String?
  code              String                   @unique
  status            DeviceRegistrationStatus @default(READY)
  note              String?
  expiresAt         DateTime?
  usedAt            DateTime?
  usedByIotDeviceId String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  merchantAccount MerchantAccount? @relation(fields: [merchantAccountId], references: [id], onDelete: SetNull)
  branch          Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  usedByIotDevice IotDevice?       @relation(fields: [usedByIotDeviceId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, expiresAt])
  @@index([merchantAccountId, branchId])
  @@map("device_registration_codes")
}

model SystemSetting {
  key       String   @id @db.Text
  value     Json
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("system_settings")
}

model PlatformBootstrapAuditLog {
  id            String   @id @db.Text
  action        String   @db.Text
  bootstrapMode String   @map("bootstrap_mode") @db.Text
  userId        String   @map("user_id") @db.Text
  email         String   @db.Text
  actorUserId   String?  @map("actor_user_id") @db.Text
  ipAddress     String?  @map("ip_address") @db.Text
  userAgent     String?  @map("user_agent") @db.Text
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("platform_bootstrap_audit_logs")
}
